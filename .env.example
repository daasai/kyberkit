# KyberKit Configuration Reference
# Copy this file to .env and fill in your values.
#
# Bun automatically loads .env before executing scripts.
# All values have sensible defaults — only ANTHROPIC_API_KEY is required.

# ============================================================================
# Model Provider
# ============================================================================

# (Required) Your Anthropic API key
ANTHROPIC_API_KEY=

# (Optional) Model provider name. Default: anthropropic
KYBER_MODEL_PROVIDER=anthropic

# (Optional) Model identifier. Default: claude-sonnet-4-20250514
KYBER_MODEL_NAME=claude-sonnet-4-20250514

# (Optional) Custom API base URL (for proxies or enterprise setups)
# KYBER_MODEL_BASE_URL=

# (Optional) Max tokens per response. Default: 4096
# KYBER_MODEL_MAX_TOKENS=4096

# ============================================================================
# Agent
# ============================================================================

# (Optional) Agent name. Default: default
# KYBER_AGENT_NAME=my-agent

# (Optional) Workspace user namespace for assets. Default: default
# Assets resolve to <cwd>/spaces/{KYBER_USER_NAME}
# KYBER_USER_NAME=default

# (Optional) Workspace id inside user namespace. Default: default
# Workspace path resolves to <cwd>/spaces/{user}/workspaces/{workspaceId}
# KYBER_WORKSPACE_ID=default

# (Optional) Override spaces root. Default: <cwd>/spaces
# KYBER_SPACES_ROOT=./spaces

# (Optional) System prompt for agent behavior
# KYBER_AGENT_SYSTEM_PROMPT=You are a helpful assistant.

# (Optional) Path to a file containing the system prompt
# KYBER_AGENT_SYSTEM_PROMPT_FILE=./system-prompt.md

# (Optional) Reliability layer mode for AgentSession.
# 'real'    — persist memory/checkpoints under <cwd>/.kyberkit/runtime/ (default)
# 'inmemory'— allocate a temp dir per session; auto-cleaned on session.close()
#             Useful for quick scripts and CI where file persistence is not needed.
# KYBER_RELIABILITY=real

# ============================================================================
# Permissions
# ============================================================================

# (Optional) Comma-separated list of allowed permissions
# Default: read_fs,exec_shell,read_net,read_env
# KYBER_PERMS_ALLOWED=read_fs,exec_shell,read_net,read_env

# (Optional) Comma-separated list of denied permissions
# KYBER_PERMS_DENIED=

# (Optional) Comma-separated list of allowed file system paths
# Default: ./
# KYBER_PERMS_ALLOWED_PATHS=./

# (Optional) Comma-separated list of allowed network domains
# KYBER_PERMS_ALLOWED_DOMAINS=

# ============================================================================
# Skills
# ============================================================================

# (Optional) Comma-separated paths to skill directories
# Default: ./skills
# KYBER_SKILL_PATHS=./skills,./custom-skills

# ============================================================================
# MCP Servers
# ============================================================================
# Servers are indexed by number: KYBER_MCP_SERVER_1_*, KYBER_MCP_SERVER_2_*, etc.
# The server list is read sequentially until no server with the next index is found.
#
# For each server:
#   KYBER_MCP_SERVER_N_NAME       - Server name (required to enable this server)
#   KYBER_MCP_SERVER_N_TRANSPORT  - stdio | sse | streamable-http (default: stdio)
#   KYBER_MCP_SERVER_N_COMMAND    - Command to run (for stdio transport)
#   KYBER_MCP_SERVER_N_ARGS       - Comma-separated command arguments
#   KYBER_MCP_SERVER_N_URL        - Server URL (for sse / streamable-http transport)
#   KYBER_MCP_SERVER_N_TRUST      - trusted | sandboxed | untrusted (default: sandboxed)
#
# Example: Filesystem MCP server
# KYBER_MCP_SERVER_1_NAME=filesystem
# KYBER_MCP_SERVER_1_TRANSPORT=stdio
# KYBER_MCP_SERVER_1_COMMAND=npx
# KYBER_MCP_SERVER_1_ARGS=-y,@modelcontextprotocol/server-filesystem,/path/to/watch
# KYBER_MCP_SERVER_1_TRUST=sandboxed
#
# Example: GitHub MCP server (SSE)
# KYBER_MCP_SERVER_2_NAME=github
# KYBER_MCP_SERVER_2_TRANSPORT=sse
# KYBER_MCP_SERVER_2_URL=http://localhost:3001
# KYBER_MCP_SERVER_2_TRUST=sandboxed
