{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "standup-brief-output",
  "type": "object",
  "required": ["title", "metrics", "insights"],
  "properties": {
    "title": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "delta": { "type": "string" },
          "warning": { "type": "boolean" }
        }
      }
    },
    "task_summary": { "type": "string" },
    "insights": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string" }
    },
    "follow_up": { "type": "string" }
  }
}
