{
  "name": "kyberkit",
  "version": "2.0.0-alpha.1",
  "private": true,
  "type": "module",
  "bin": {
    "kyberkit": "bin/kyberkit"
  },
  "exports": {
    "./runtime/KyberRuntime.js": "./src/runtime/KyberRuntime.ts",
    "./runtime/AgentSession.js": "./src/runtime/AgentSession.ts",
    "./runtime/AgentExecutionContext.js": "./src/runtime/AgentExecutionContext.ts",
    "./runtime/audit/AuditLogger.js": "./src/runtime/audit/AuditLogger.ts",
    "./runtime/paths/PathResolver.js": "./src/runtime/paths/PathResolver.ts",
    "./runtime/config/UserConfigStore.js": "./src/runtime/config/UserConfigStore.ts",
    "./util/binaryFileExtract.js": "./src/util/binaryFileExtract.ts",
    "./config/ConfigLoader.js": "./src/config/ConfigLoader.ts",
    "./types/skill-suggestion.js": "./src/types/skill-suggestion.ts",
    "./events/EventBus.js": "./src/events/EventBus.ts",
    "./types/events.js": "./src/types/events.ts",
    "./eval/EvalRuntime.js": "./src/eval/EvalRuntime.ts",
    "./runtime/ExecutionScope.js": "./src/runtime/ExecutionScope.ts"
  },
  "scripts": {
    "test": "bun test ./src",
    "test:live:sprint2": "KYBER_RUN_LIVE_TESTS=true bun test ./src/runtime/Sprint2Live.integration.test.ts",
    "demo:sprint2": "bun run ./scripts/sprint2-workspace-demo.ts",
    "repl-test": "bun run ./scripts/repl-test.ts",
    "stream-test": "bun run ./scripts/stream-test.ts",
    "chat": "bun run bin/kyberkit chat",
    "chat:no-tui": "bun run bin/kyberkit chat --no-tui",
    "web:api": "bun run ./src/console-server/server.ts",
    "web:smoke:api": "bun run ./scripts/web-console-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/openai": "^3.0.58",
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.174",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "bun-types": "latest",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
